{
  "family": "app",
  "executionRoleArn": "arn:aws:iam::831411500862:role/EscEc2BasicServiceExecutionRole",
  "taskRoleArn": "arn:aws:iam::831411500862:role/EcsEc2BasicTaskRole",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": [ 
    "FARGATE" 
  ],

  "containerDefinitions": [
    {
      "name": "app",
      "image": "831411500862.dkr.ecr.us-east-1.amazonaws.com/app",
      "essential": true,
      "portMappings": [
        {
          "name": "app",
          "containerPort": 4567,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
            "awslogs-group": "ecs-ec2-fargate",
            "awslogs-region": "us-east-1",
            "awslogs-stream-prefix": "app"
        }
      }
    }
  ]
}
