# ==========================================
# Frontend & JavaScript (Three.js projects)
# ==========================================
**/node_modules/
**/.pnpm-store/
**/.yarn/
**/dist/
**/build/
**/.next/
**/.nuxt/
**/.cache/
**/.env
**/.env.local
**/.env.*.local
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ==========================================
# DevOps & Cloud (Kube, AWS, Bash)
# ==========================================
# AWS / CloudFormation local files
**/.aws/
**/.cfn/
**/sam-config.toml
**/.aws-sam/

# Kubernetes / Terraform / Global DevOps
**/.kube/config
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/kubeconfig
**/*.kubeconfig

# Secrets & Keys (Never commit these!)
**/*.pem
**/*.key
**/*.pub
**/secrets/
**/*.secret

# ==========================================
# Operating System & IDE Garbage
# ==========================================
# macOS
**/.DS_Store
**/.AppleDouble
**/.LSOverride

# IDEs (VS Code, WebStorm, etc.)
**/.vscode/
!**/.vscode/extensions.json
**/.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.swp

# python
**/*.venv/
